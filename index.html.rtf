<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>$BASEDOG 🐕 | Live Meme Feed</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');
    body { background: #0a0a0a; color: #fff; }
    .meme-font { font-family: "Press Start 2P", system-ui; }
    .post-card { transition: all 0.3s ease; }
    .post-card:hover { transform: translateY(-4px); box-shadow: 0 0 20px rgba(255, 215, 0, 0.3); }
    .neon-text { text-shadow: 0 0 10px #ffd700, 0 0 20px #ffd700; }
  </style>
</head>
<body class="bg-zinc-950">
  <div class="border-b border-yellow-500/30 bg-black/60">
    <div class="max-w-4xl mx-auto px-6 py-5 flex items-center justify-between">
      <div class="flex items-center gap-x-4">
        <div class="text-5xl">🐕</div>
        <div>
          <h1 class="meme-font text-3xl font-bold text-yellow-400">$BASEDOG</h1>
          <p class="text-yellow-500 text-xs tracking-widest">THE MOST BASED DOG ON CHAIN</p>
        </div>
      </div>
      <div class="flex items-center gap-x-2 text-sm">
        <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
        <span class="text-green-400">LIVE</span>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-6 py-10">
    <div class="text-center mb-10">
      <div class="inline px-4 py-1 bg-yellow-400 text-black text-xs font-bold rounded-full">REAL-TIME FROM X</div>
      <h2 class="meme-font text-5xl mt-4 mb-2">LIVE POSTS</h2>
      <p class="text-yellow-400">@officialbasedog</p>
    </div>

    <div id="posts" class="space-y-4 max-w-2xl mx-auto"></div>
  </div>

  <script>
    const postsContainer = document.getElementById('posts');

    function addPost(post) {
      const div = document.createElement('div');
      div.className = `post-card bg-zinc-900 border border-yellow-500/20 rounded-2xl p-5`;
      div.innerHTML = `
        <div class="flex gap-x-4">
          <div class="text-4xl">🐾</div>
          <div class="flex-1">
            <div class="flex items-center gap-x-2 mb-1">
              <span class="font-bold">@officialbasedog</span>
              <span class="text-[10px] px-2 py-0.5 bg-yellow-400 text-black rounded">BASED</span>
            </div>
            <p class="text-lg">${post.text}</p>
            <div class="text-xs text-yellow-500/60 mt-3">${new Date(post.created_at).toLocaleTimeString()}</div>
          </div>
        </div>
      `;
      postsContainer.prepend(div);
      if (postsContainer.children.length > 8) postsContainer.lastChild.remove();
    }

    // Connect to backend stream
    const eventSource = new EventSource('/api/stream');
    eventSource.onmessage = function(event) {
      const post = JSON.parse(event.data);
      addPost(post);
    };
  </script>
</body>
</html>